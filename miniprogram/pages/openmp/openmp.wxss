.container {
	padding: 32rpx;
}

.title,
.option-title {
	font-size: 28rpx;
	font-weight: 600;
}

.platform {
	height: 160rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
	margin-top: 40rpx;
	overflow-x: auto;
	white-space: nowrap;
}

.scroll-view::-webkit-scrollbar {
	display: none;
}

.platform-item {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	width: 160rpx;
	border-radius: 12rpx;
	padding: 20rpx;
	box-sizing: border-box;
	flex: 0 0 auto;
}

.platform-box:nth-child(n + 2) {
	margin-left: 20rpx;
}

.box-select {
	background-color: #e1e1e1;
}

.platform-icon {
	overflow: hidden;
	width: 68rpx;
	height: 68rpx;
	border-radius: 50%;
}

.platform-name {
	font-size: 28rpx;
	line-height: 36rpx;
	height: 36rpx;
	margin-top: 6rpx;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
	width: 100%;
	text-align: center;
}

.user-input {
	margin-top: 40rpx;
	font-size: 28rpx;
	height: 100rpx;
	line-height: 100rpx;
	background-color: #fff;
	color: #515151;
	border: 1rpx solid #ebebeb;
	border-radius: 12rpx;
	padding: 20rpx 24rpx;
	box-sizing: border-box;
}

.user-textarea {
	margin-top: 24rpx;
	font-size: 28rpx;
	width: 100%;
	height: 200rpx;
	padding: 24rpx;
	min-height: 200rpx;
	color: #515151;
	background-color: #fff;
	border: 1rpx solid #ebebeb;
	border-radius: 12rpx;
	box-sizing: border-box;
}

.mt40 {
	margin-top: 40rpx;
}

.env-type {
	margin-top: 24rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
	flex-wrap: wrap;
}

.env-box {
	display: flex;
	justify-content: center;
	align-items: center;
	white-space: nowrap;
	padding-right: 24rpx;
}

.env-name {
	margin-left: 4rpx;
}

.btn-list {
	margin-top: 40rpx;
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 24rpx;
}

.btn-use {
	width: 45%;
	line-height: 80rpx;
	color: #fff;
	background-color: #1aad19;
	border-radius: 8rpx;
	text-align: center;
}

.option-box {
	margin-top: 64rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
}

.option-name {
	font-size: 28rpx;
}

.option-icon {
	font-size: 24rpx;
	border-radius: 8rpx;
	background-color: #e1e1e1;
	padding: 8rpx 12rpx;
}

.urllist {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	margin-top: 40rpx;
}

.urllist-box {
	display: flex;
	justify-content: flex-start;
	align-items: center;
	width: 100%;
	white-space: nowrap;
	padding: 24rpx 0;
	border-top: 1rpx solid #ebebeb;
}

.urllist-icon {
	overflow: hidden;
	width: 36rpx;
	height: 36rpx;
	border-radius: 50%;
	margin-right: 12rpx;
}

.urllist-url {
	font-size: 28rpx;
	flex: 1;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
	margin-right: 12rpx;
}

.urllist-time {
	font-size: 24rpx;
	color: #999;
}

.btn-icon {
	overflow: hidden;
	width: 56rpx;
	height: 56rpx;
	border-radius: 50%;
	margin-left: 14rpx;
}
