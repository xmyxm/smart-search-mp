.container {
	width: 100%;
	justify-content: center;
	align-items: center;
}

.menu-list {
	margin-top: 48rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	border-radius: 12rpx;
	background-color: #fff;
	padding: 32rpx 40rpx;
	width: 94%;
	box-sizing: border-box;
}

.item-color {
	line-height: 160rpx;
	color: rgba(0, 0, 0, 0.9);
	flex: 1;
}

.item-icon {
	width: 80rpx;
	height: 80rpx;
	border-radius: 50%;
}
