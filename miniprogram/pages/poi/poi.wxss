.floating-window {
	position: fixed;
	top: 280rpx;
	right: 0;
	width: 140rpx;
	height: 60rpx;
	font-size: 24rpx;
	color: #fff;
	background-color: rgba(0, 0, 0, 0.45);
	display: flex;
	justify-content: center;
	align-items: center;
	border-radius: 20rpx 0 0 20rpx;
	z-index: 1000;
}

.container {
	padding: 32rpx;
}

.title,
.option-title {
	font-size: 28rpx;
	font-weight: 600;
}

.mt40 {
	margin-top: 40rpx;
}

.poi-type {
	margin-top: 40rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
	flex-wrap: wrap;
}

.poi-box {
	display: flex;
	justify-content: center;
	align-items: center;
	white-space: nowrap;
	padding-right: 24rpx;
}

.poi-name {
	margin-left: 4rpx;
}

.platform {
	display: flex;
	justify-content: flex-start;
	align-items: center;
	margin-top: 40rpx;
}

.platform-box {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	width: 160rpx;
	border-radius: 12rpx;
	padding: 20rpx;
}

.box-select {
	background-color: #e1e1e1;
}

.platform-icon {
	overflow: hidden;
	width: 68rpx;
	height: 68rpx;
	border-radius: 50%;
}

.platform-name {
	font-size: 28rpx;
	line-height: 36rpx;
	height: 36rpx;
	margin-top: 6rpx;
}

.user-content {
	margin-top: 40rpx;
	min-height: 300rpx;
	width: 100%;
	background-color: #e1e1e1;
	border-radius: 12rpx;
	padding: 24rpx;
	color: #515151;
	box-sizing: border-box;
}

.app-content {
	margin-top: 24rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
}

.appid-name,
.appid-content {
	font-size: 28rpx;
}

.appid-content {
	margin-left: 20rpx;
}

.btn-list {
	margin-top: 40rpx;
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 24rpx;
}

.btn-use,
.dialog-btn-use {
	line-height: 80rpx;
	color: #fff;
	background-color: #1aad19;
	border-radius: 8rpx;
	text-align: center;
}

.btn-use {
	width: 30%;
}

.dialog-btn-use {
	width: 45%;
}

.option-box {
	margin-top: 40rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
}

.option-name {
	font-size: 28rpx;
}

.option-icon {
	font-size: 24rpx;
	border-radius: 8rpx;
	background-color: #e1e1e1;
	padding: 8rpx 12rpx;
}

.urllist {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	margin-top: 40rpx;
}

.urllist-box {
	display: flex;
	justify-content: flex-start;
	align-items: center;
	width: 100%;
	white-space: nowrap;
	padding: 24rpx 0;
	border-top: 1rpx solid #ebebeb;
}

.urllist-icon {
	overflow: hidden;
	width: 36rpx;
	height: 36rpx;
	border-radius: 50%;
	margin-right: 12rpx;
}

.btn-icon {
	overflow: hidden;
	width: 56rpx;
	height: 56rpx;
	border-radius: 50%;
	margin-left: 14rpx;
}

.urllist-url {
	font-size: 28rpx;
	flex: 1;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
	margin-right: 12rpx;
}

.urllist-time {
	font-size: 24rpx;
	color: #999;
}

.modal-main {
	background-color: #fff;
	padding: 40rpx;
	border-radius: 24rpx;
}

.modal-title {
	width: 100%;
	font-size: 36rpx;
	text-align: center;
	font-weight: 600;
}

.modal-content {
	margin-top: 24rpx;
	min-height: 300rpx;
	width: 100%;
	background-color: #f8f8f8;
	border-radius: 12rpx;
	padding: 24rpx;
	color: #515151;
	box-sizing: border-box;
}
