.tmpl-list {
	padding: 32rpx;
}

.tmpl-list .title {
	font-size: 28rpx;
	font-weight: 600;
	margin-bottom: 16rpx;
}

.tmpl-list .tmpl-boxs {
	display: flex;
	flex-direction: column;
	justify-content: flex-start;
	align-items: flex-start;
}

.tmpl-list .tmpl-item {
	width: 100%;
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-top: 24rpx;
	padding: 20rpx 0;
	border-bottom: 1rpx solid #ebebeb;
}

.tmpl-list .tmpl-item:last-of-type {
	border-bottom: none;
}

.tmpl-list .tmpl-item-box {
	display: flex;
	flex-direction: row;
	justify-content: flex-start;
	align-items: center;
}

.tmpl-list .tmpl-item-btn {
	display: flex;
	flex-direction: row;
	justify-content: flex-end;
	align-items: center;
	background-color: #1aad19;
	color: #fff;
	font-size: 24rpx;
	border-radius: 8rpx;
	padding: 6rpx 12rpx;
}

.tmpl-list .tmpl-item-img {
	width: 40rpx;
	height: 40rpx;
	margin-right: 20rpx;
	border-radius: 50%;
}

.tmpl-list .tmpl-item-title {
	font-size: 28rpx;
}

.btn-list {
	padding: 40rpx 32rpx;
	display: flex;
	flex-wrap: nowrap;
	justify-content: space-between;
	align-items: center;
	gap: 24rpx;
}

.btn-item {
	flex: 1;
	height: 80rpx;
	color: #fff;
	background-color: #1aad19;
	border-radius: 8rpx;
	white-space: nowrap;
}

.log-content {
	padding: 32rpx;
}

.log-title-box {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}

.log-title-content {
	font-size: 28rpx;
	font-weight: 600;
}

.log-clear-btn {
	font-size: 24rpx;
	color: #515151;
	background-color: #e1e1e1;
	border-radius: 8rpx;
	padding: 8rpx 16rpx;
}

.user-content {
	margin-top: 24rpx;
	min-height: 800rpx;
	width: 100%;
	background-color: #e1e1e1;
	border-radius: 12rpx;
	padding: 24rpx;
	color: #515151;
	box-sizing: border-box;
}
