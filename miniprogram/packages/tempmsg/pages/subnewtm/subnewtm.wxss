.container {
	padding: 40rpx 32rpx;
}

.btn-qrcode {
	width: auto;
	height: 80rpx;
	padding: 0 32rpx;
	color: #fff;
	background-color: #1aad19;
	margin: 40rpx auto;
	border-radius: 8rpx;
	white-space: nowrap;
}

.log-content {
	padding: 32rpx;
}

.log-title-box {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}

.log-title-content {
	font-size: 28rpx;
	font-weight: 600;
}

.log-clear-btn {
	font-size: 24rpx;
	color: #515151;
	background-color: #e1e1e1;
	border-radius: 8rpx;
	padding: 8rpx 16rpx;
}

.user-content {
	margin-top: 24rpx;
	min-height: 800rpx;
	width: 100%;
	background-color: #e1e1e1;
	border-radius: 12rpx;
	padding: 24rpx;
	color: #515151;
	box-sizing: border-box;
}
