.container {
	padding: 40rpx 32rpx;
}

.user-content {
	min-height: 400rpx;
	width: 100%;
	background-color: #e1e1e1;
	border-radius: 12rpx;
	padding: 24rpx;
	color: #515151;
	box-sizing: border-box;
}

.btn-qrcode {
	width: auto;
	height: 80rpx;
	padding: 0 32rpx;
	color: #fff;
	background-color: #1aad19;
	margin: 40rpx auto;
	border-radius: 8rpx;
	white-space: nowrap;
}
